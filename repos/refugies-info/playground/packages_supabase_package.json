{
  "name": "@playground/supabase",
  "version": "0.1.0",
  "description": "Shared Supabase client and utilities",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check:types": "tsc --noEmit",
    "gen:types": "supabase gen types typescript --local --schema public,storage,graphql_public > src/types.ts"
  },
  "dependencies": {
    "@playground/shared-types": "workspace:*",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "2.84.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "dotenv": "^17.2.3",
    "gray-matter": "^4.0.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "workflow": "4.0.1-beta.21"
  }
}
