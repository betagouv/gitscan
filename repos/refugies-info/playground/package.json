{
  "name": "content-playground",
  "version": "0.1.0",
  "description": "Editorial workflow platform for Refugies.info content management",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "overrides": {
      "undici-types": "6.18.2",
      "vite": "5.4.19",
      "caniuse-lite": "1.0.30001756"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "sharp"
    ]
  },
  "scripts": {
    "prepare": "husky",
    "build": "turbo build",
    "check:outdated": "pnpx taze -r --maturity-period",
    "check:types": "turbo check:types",
    "test": "turbo test",
    "clean:branches": "pnpx git-removed-branches --prune --force",
    "dev": "turbo dev dev:workflow",
    "dev:workflow": "workflow inspect runs --web",
    "format": "biome format --write .",
    "knip": "knip",
    "lint": "biome check --write .",
    "validate:docs": "tsx scripts/validate-docs.ts",
    "validate": "pnpm validate:docs && pnpm knip",
    "seed:users": "tsx scripts/seed-users.ts",
    "convert:dispositifs": "tsx scripts/convert-dispositifs.ts",
    "list:agents": "tsx scripts/list-agents.ts",
    "register:metadata-validator": "tsx scripts/register-metadata-validator-tool.ts",
    "update:metadata-schema": "tsx scripts/update-metadata-schema-block.ts",
    "generate:json": "tsx scripts/generate-json.ts",
    "generate:md": "tsx scripts/generate-md.ts",
    "copy:schema": "tsx scripts/copy-schema.ts",
    "seed:ingestion": "tsx scripts/seed-ingestion.ts",
    "di:ingest": "tsx scripts/ingest-di.ts",
    "di:extract": "tsx scripts/extract-random-records.ts",
    "di:cron": "dotenv -e .env -- sh -c 'curl -s -X GET http://localhost:3001/api/cron/di-ingestion -H \"Authorization: Bearer $CRON_SECRET\" | jq .'",
    "seed:sync": "supabase db dump --local --data-only --file supabase/seed.sql"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.6",
    "@playground/shared-types": "workspace:*",
    "@playground/supabase": "workspace:*",
    "@refugies-info/di": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "knip": "^5.70.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "tsx": "^4.20.6",
    "turbo": "^2.6.1",
    "workflow": "4.0.1-beta.21"
  },
  "lint-staged": {
    "**/*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  }
}
