{
  "name": "@playground/workflows",
  "version": "0.1.0",
  "description": "Shared workflows for Refugies.info Playground",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "check:types": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "dev:workflow": "PORT=3002 workflow inspect runs --web"
  },
  "dependencies": {
    "@playground/agents": "workspace:*",
    "@playground/airtable": "workspace:*",
    "@playground/rco": "workspace:*",
    "@playground/shared-types": "workspace:*",
    "@playground/supabase": "workspace:*",
    "gray-matter": "^4.0.3",
    "workflow": "4.0.1-beta.21"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
