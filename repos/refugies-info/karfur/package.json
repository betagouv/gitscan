{
  "private": true,
  "name": "karfur",
  "version": "0.1.0",
  "description": "Plateforme dédiée aux réfugiés",
  "author": "Soufiane Lamrissi",
  "homepage": "https://accueil-integration-refugies.fr",
  "copyright": "Copyright 2019 DiAiR",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "core-js",
      "core-js-pure",
      "esbuild",
      "mongodb-memory-server",
      "oxc-resolver",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "@codegouvfr/react-dsfr": "1.20.2",
      "baseline-browser-mapping": "^2.9.19",
      "caniuse-lite": "1.0.30001755",
      "debug": "4.4.1",
      "electron-to-chromium": "1.5.255",
      "form-data": "^4.0.4",
      "glob": "^10.5.0",
      "image-size": "^1.2.1",
      "js-yaml": "^3.14.2",
      "pbkdf2": "^3.1.3",
      "sha.js": "^2.4.12",
      "stylus": "npm:noop3@^1000.0.0",
      "tmp": "^0.2.4",
      "undici": "6.21.2",
      "validator": "^13.15.20",
      "mdast-util-to-hast": ">=13.2.1",
      "react-server-dom-webpack": ">=19.0.2",
      "node-forge": ">=1.3.2",
      "jsonwebtoken>jws": "^3.2.3",
      "google-auth-library>jws": "^4.0.1",
      "gtoken>jws": "^4.0.1"
    },
    "patchedDependencies": {
      "@codegouvfr/react-dsfr@1.20.2": "patches/@codegouvfr__react-dsfr@1.20.2.patch"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19"
      }
    }
  },
  "scripts": {
    "clean:branches": "pnpm dlx git-removed-branches --prune --force",
    "clean:cache": "rimraf -g \"**/.turbo\" \"**/.next\" \"**/dist\" \"**/.cache\" \"**/.expo\" \"**/storybook-static\" \"**/build\" \"**/__pycache__\"",
    "clean:modules": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "clean:store": "rm -rf $(pnpm store path)",
    "build": "turbo build",
    "build:api-types": "turbo build --filter=@refugies-info/api-types",
    "build:client": "turbo build --filter=@refugies-info/client",
    "build:server": "turbo build --filter=@refugies-info/server",
    "build:storybook": "turbo build --filter=@refugies-info/storybook",
    "build:mobile:android": "cd apps/mobile && eas build --profile development --platform android",
    "build:mobile:ios": "cd apps/mobile && eas build --profile development --platform ios",
    "check:dependency-version-consistency": "pnpm check-dependency-version-consistency .",
    "check:types": "turbo check:types",
    "check:types:api-types": "turbo check:types --filter=@refugies-info/api-types",
    "check:types:client": "turbo check:types --filter=@refugies-info/client",
    "check:types:server": "turbo check:types --filter=@refugies-info/server",
    "check:types:mobile": "turbo check:types --filter=@refugies-info/mobile",
    "check:types:ui": "turbo check:types --filter=@refugies-info/ui",
    "dev": "turbo dev",
    "dev:ui": "turbo dev --filter=@refugies-info/ui",
    "dev:client": "turbo dev --filter=@refugies-info/client --filter=@refugies-info/ui",
    "dev:server": "turbo dev --filter=@refugies-info/server",
    "dev:mobile": "turbo dev --filter=@refugies-info/mobile --filter=@refugies-info/server",
    "dev:storybook": "turbo dev --filter=@refugies-info/storybook --filter=@refugies-info/ui",
    "update-icons": "react-dsfr update-icons --silent --projectDir ./",
    "start:client": "pnpm --filter @refugies-info/client start",
    "start:server": "pnpm --filter @refugies-info/server start",
    "start:mobile": "pnpm --filter @refugies-info/mobile start",
    "test": "turbo test",
    "test:client": "turbo test --filter=@refugies-info/client -- $*",
    "test:server": "turbo test --filter=@refugies-info/server -- $*",
    "test:mobile": "turbo test --filter=@refugies-info/mobile -- $*",
    "lint": "turbo lint --filter=!@refugies-info/mobile",
    "lint:api-types": "turbo lint --filter=@refugies-info/api-types",
    "lint:client": "turbo lint --filter=@refugies-info/client",
    "lint:server": "turbo lint --filter=@refugies-info/server",
    "lint:mobile": "turbo lint --filter=@refugies-info/mobile",
    "lint:style": "stylelint \"**/*.css\" \"**/*.scss\"",
    "client:i18n:export": "pnpm --filter @refugies-info/client i18n:export",
    "client:i18n:import": "pnpm --filter @refugies-info/client i18n:import",
    "pr:stg": "gh pr create -B staging -H dev -l release -t '[STG] Release' -b ''",
    "pr:prod": "gh pr create -B production -H staging -l release -t '[PROD] Release' -b ''",
    "pr:prod:client": "gh pr create -B master-frontend -H staging-frontend -l release -t '[PROD-FRONT] Release' -b ''",
    "pr:stg:client": "gh pr create -B staging-frontend -H dev -l release -t '[STG-FRONT] Release' -b ''",
    "pr:prod:mobile": "gh pr create -B master-mobile -H staging-mobile -l release -t '[PROD-MOBILE] Release' -b ''",
    "pr:stg:mobile": "gh pr create -B staging-mobile -H dev -l release -t '[STG-MOBILE] Release' -b ''",
    "pr:prod:server": "gh pr create -B master-backend -H staging-backend -l release -t '[PROD-BACK] Release' -b ''",
    "pr:stg:server": "gh pr create -B staging-backend -H dev -l release -t '[STG-BACK] Release' -b ''",
    "eas:build": "cd apps/mobile && eas build --profile development",
    "eas:build:android": "cd apps/mobile && eas build --profile development --platform android",
    "eas:build:ios": "cd apps/mobile && eas build --profile development --platform ios",
    "eas:build:staging": "cd apps/mobile && eas build --profile staging",
    "eas:build:android:staging": "cd apps/mobile && eas build --profile staging --platform android",
    "eas:build:ios:staging": "cd apps/mobile && eas build --profile staging --platform ios",
    "eas:update": "cd apps/mobile && eas update --channel staging",
    "eas:update:android": "cd apps/mobile && eas update --channel staging --platform android",
    "eas:update:ios": "cd apps/mobile && eas update --channel staging --platform ios",
    "eas:submit": "cd apps/mobile && eas submit --profile production",
    "eas:submit:android": "cd apps/mobile && eas submit --profile production --platform android",
    "eas:submit:ios": "cd apps/mobile && eas submit --profile production --platform ios",
    "format": "turbo format",
    "prepare": "husky",
    "migrate": "tsx migrations/cli.ts",
    "storybook": "pnpm dev:storybook",
    "storybook:publish": "pnpm --filter @refugies-info/storybook storybook:publish",
    "knip": "knip",
    "update-dependencies": "pnpm update -i --filter api-types --filter ui --filter server --filter client --filter mobile --filter storybook"
  },
  "engines": {
    "node": "24.11.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.7",
    "@codegouvfr/react-dsfr": "1.20.2",
    "@refugies-info/api-types": "workspace:*",
    "@types/node": "^22.18.0",
    "check-dependency-version-consistency": "^4.1.1",
    "dotenv": "^17.2.3",
    "husky": ">=9.1.6",
    "knip": "^5.63.0",
    "lint-staged": "^15.5.2",
    "mongo-migrate-ts": "^1.6.3",
    "mongodb": "^6.20.0",
    "rimraf": "^6.0.1",
    "stylelint": "^16.23.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "tsx": "^4.20.5",
    "turbo": "2.6.0",
    "typescript": "^5.9.2"
  },
  "volta": {
    "node": "24.11.1",
    "pnpm": "10.23.0"
  },
  "lint-staged": {
    "*.{css,scss}": "stylelint --fix",
    "*.{js,jsx,ts,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  },
  "packageManager": "pnpm@10.26.1"
}
