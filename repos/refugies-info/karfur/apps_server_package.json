{
  "name": "@refugies-info/server",
  "version": "0.1.0",
  "description": "Plateforme dédiée aux réfugiés",
  "author": "Soufiane Lamrissi",
  "homepage": "https://refugies.info",
  "copyright": "Copyright 2019 DiAiR",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm gen:tsoa && pnpm build:ncc",
    "build:dev": "pnpm gen:tsoa && tsc",
    "build:ncc": "NODE_OPTIONS='--max-old-space-size=4096' ncc build src/server.ts -o dist",
    "check:types": "pnpm gen:tsoa && tsc --noEmit",
    "dev": "pnpm build:dev && concurrently \"nodemon\" \"nodemon -x tsoa spec-and-routes\"",
    "gen:tsoa": "tsoa spec-and-routes",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "pr:prod": "gh pr create -B master-backend -H staging-backend -l release -t '[PROD-BACK] Release' -b ''",
    "pr:stg": "gh pr create -B staging-backend -H dev -l release -t '[STG-BACK] Release' -b ''",
    "start": "node dist/index.js",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.3",
    "@getbrevo/brevo": "^3.0.1",
    "@google-cloud/translate": "^8.5.1",
    "@refugies-info/api-types": "workspace:*",
    "@sendgrid/mail": "^8.1.4",
    "@slack/webhook": "^7.0.6",
    "@typegoose/typegoose": "^12.20.0",
    "airtable": "^0.12.2",
    "algoliasearch": "^5.42.0",
    "axios": "^1.12.2",
    "cloudinary": "^2.7.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "expo-server-sdk": "^4.0.0",
    "express": "^4.21.2",
    "express-form-data": "^3.0.1",
    "google-auth-library": "^9.15.0",
    "googleapis": "^165.0.0",
    "jwt-simple": "^0.5.5",
    "lodash": "^4.17.20",
    "microsoft-cognitiveservices-speech-sdk": "^1.45.0",
    "moment": "^2.29.4",
    "mongoose": "^8.19.4",
    "node-cache": "^5.1.2",
    "password-hash": "^1.2.2",
    "path-to-regexp": ">=0.1.12",
    "phone": "^3.1.67",
    "ts-node": "^10.9.2",
    "tsoa": "^6.6.0",
    "twilio": "^5.8.2",
    "uniqid": "^5.0.3",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@refugies-info/typescript-config": "workspace:*",
    "@tsoa/runtime": "^6.5.1",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-form-data": "^2.0.2",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.20",
    "@types/node": "^22.18.0",
    "@types/password-hash": "^1.2.20",
    "@types/uniqid": "^5.3.0",
    "@vercel/ncc": "^0.38.3",
    "babel-jest": "^29.7.0",
    "concurrently": "^9.2.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "10.1.4",
    "nodemon": "^3.1.7",
    "ts-jest": "^29.4.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": "24.11.1"
  },
  "volta": {
    "node": "24.11.1",
    "pnpm": "10.23.0"
  }
}
