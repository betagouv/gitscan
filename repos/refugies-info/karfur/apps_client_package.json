  "scripts": {
    "build": "next build --no-lint",
    "postbuild": "mkdir -p ./.dist && cp -R .next/standalone/* ./.dist/ && cp -R .next/static ./.dist/apps/client/.next/ && cp -R ./public ./.dist/apps/client/",
    "check:types": "tsc --noEmit",
    "dev": "wait-on http://localhost:8000/health && next dev",
    "i18n:clean": "node ./scripts/clean-i18n.js",
    "i18n:import": "node ./scripts/import-i18n.js",
    "i18n:export": "node ./scripts/export-i18n.js",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "pr:prod": "gh pr create -B master-frontend -H staging-frontend -l release -t '[PROD-FRONT] Release' -b ''",
    "pr:stg": "gh pr create -B staging-frontend -H dev -l release -t '[STG-FRONT] Release' -b ''",
    "start": "node ./.dist/apps/client/server.js",
    "test-with-coverage": "jest --coverage && cat ./coverage/lcov.info | codacy-coverage",
    "test": "jest --runInBand"
  },
  "proxy": "http://localhost:8000",
  "bugs": {
    "url": "https://github.com/entrepreneur-interet-general/karfur/issues"
