    "@storybook/addon-themes": "10.1.8",
    "@storybook/nextjs": "10.1.8",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^20.19.11",
    "@types/react": "19.0.14",
    "@types/react-dom": "19.2.1",
    "chromatic": "^13.1.4",
