{
  "name": "@anssi-portail/svelte",
  "private": true,
  "version": "1.0.0",
  "description": "Partie svelte pour le catalogue du portail de l’ANSSI",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch --mode=development",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pretest": "npm-run-all --parallel typecheck lint",
    "test": "vitest run",
    "test:ci": "vitest run",
    "typecheck": "tsc --noEmit && svelte-check",
    "watch": "vite build -w --minify false"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/qrcode": "^1.5.6",
    "eslint": "^9.39.3",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^16.5.0",
    "prettier": "3.3.3",
    "prettier-plugin-svelte": "^3.5.0",
    "sass": "^1.97.3",
    "svelte": "^5.53.5",
    "svelte-check": "^4.4.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.4.1",
    "vitest": "^3.2.4",
    "vitest-localstorage-mock": "^0.1.2"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "dompurify": "^3.3.1",
    "npm-run-all2": "^8.0.4",
    "qrcode": "^1.5.4"
  },
  "main": "svelte.config.js",
  "directories": {
    "test": "test"
  }
}
