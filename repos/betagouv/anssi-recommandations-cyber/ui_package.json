{
  "name": "mesquestionscyber",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json --threshold error && tsc -p tsconfig.node.json",
    "lint:check": "eslint .",
    "lint:fix": "eslint --fix .",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "preinstall": "npx only-allow@1.2.2 pnpm",
    "test": "pnpm run svelte:check && vitest run",
    "svelte:check": "svelte-check --tsconfig ./tsconfig.app.json"
  },
  "lint-staged": {
    "*.{ts,js,json,css,md,svelte}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.svelte": [
      "svelte-check --tsconfig ./tsconfig.app.json --threshold error"
    ]
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.3",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^22.19.13",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^16.5.0",
    "lint-staged": "^16.2.7",
    "prettier": "3.6.2",
    "prettier-plugin-svelte": "^3.5.0",
    "sass-embedded": "^1.97.3",
    "svelte": "^5.53.5",
    "svelte-check": "^4.4.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@lab-anssi/ui-kit": "^1.43.0",
    "dompurify": "^3.3.1",
    "marked": "^16.4.2",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "rollup": "^4.59.0",
      "svelte": "^5.53.5",
      "immutable": "^5.1.5"
    }
  }
}
